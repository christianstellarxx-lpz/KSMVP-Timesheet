// KSMVP VA Tasks — data model
// All timestamps are stored in UTC and displayed in America/New_York (ET).
//
// DATABASE: PostgreSQL, for both local dev and production (e.g. Vercel).
// Use a hosted Postgres (Neon, Vercel Postgres, Supabase, …) and point
// DATABASE_URL at it — the same URL works locally and in production.
//
// Roles/status are stored as validated strings (not DB enums), hours are Float,
// and workDate is a plain DateTime anchored to ET-midnight UTC. See src/lib/time.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Uses the DIRECT (non-pooled) connection for both runtime and migrations —
  // simplest and most reliable at this scale. Vercel/Neon's integrated Postgres
  // sets DATABASE_URL_UNPOOLED automatically; for an external database, point it
  // at your connection string. The same value works locally and in production.
  url = env("DATABASE_URL_UNPOOLED")
}

// Role values: "ADMIN" | "VA_ADMIN" | "VA" | "INTERN"   (see src/lib/session.ts)
// EntryStatus values: "OPEN" | "CLOSED" | "INCOMPLETE"

model User {
  id           String   @id @default(cuid())
  role         String
  name         String
  title        String   @default("") // job position, e.g. "Chief Executive Officer"
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  // Reserved for future per-manager assignment; not used for scoping today
  // (the admin dashboard is org-wide). Kept as a self-relation.
  clientId String?
  client   User?   @relation("ClientVAs", fields: [clientId], references: [id], onDelete: SetNull)
  vas      User[]  @relation("ClientVAs")

  // Time entries this user (as a VA) owns.
  timeEntries TimeEntry[] @relation("VAEntries")

  // Comments this user (as an admin / VA admin) has written on entries.
  authoredComments Comment[] @relation("CommentAuthor")

  // Daily Flappy Bird scores (VA dashboard game).
  gameScores GameScore[] @relation("GameScores")

  // Sales-desk notices this user sent (Sales Producer) / received (team channel).
  sentNotices     Notice[] @relation("NoticeSender")
  receivedNotices Notice[] @relation("NoticeRecipient")

  @@index([clientId])
  @@index([role])
}

model TimeEntry {
  id   String @id @default(cuid())
  vaId String
  va   User   @relation("VAEntries", fields: [vaId], references: [id], onDelete: Cascade)

  // The ET calendar day this entry belongs to (stored at ET-midnight, UTC-normalized).
  // Used for grouping/sorting so entries near midnight land on the intended day.
  workDate DateTime

  timeIn      DateTime? // UTC; null until set
  timeOut     DateTime? // UTC; null until closed
  hoursWorked Float?    // computed on close; null while open/incomplete

  startOfDayTasks String
  urgentNeed      String? // null / empty => no urgent flag
  endOfDayTasks   String? // null until closed

  // "WORK" (a clocked shift) | "PTO" (paid time off / vacation, credited 8h)
  entryType String   @default("WORK")
  status    String   @default("OPEN") // OPEN | CLOSED | INCOMPLETE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Scheduled publish time (UTC) for the End-of-Day report — the "Atake"
  // scheduler. When set and still in the future, the entry is held back from
  // the admin dashboard until this instant (5:00 PM ET on the work date).
  // Null = visible to admins immediately (PTO, resolved stale sessions, and any
  // entries created before this feature).
  publishAt DateTime?

  // Admin feedback on this entry's start-of-day / end-of-day report.
  comments Comment[]

  @@index([vaId, workDate])
  @@index([status])
  // Fast lookup / integrity for the "at most one OPEN entry per VA" guard.
  // Enforced at the application layer inside a transaction; see src/lib/timeEntries.ts.
  @@index([vaId, status])
  @@index([publishAt])
}

// A note an admin (or VA admin) leaves on a VA's time entry. The VA sees it as
// feedback on their dashboard; `readAt` stays null until they've viewed it,
// which drives the "new comment" notification.
model Comment {
  id      String    @id @default(cuid())
  entryId String
  entry   TimeEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  // Which part of the entry this is about: "START" | "END" | "GENERAL".
  target String @default("GENERAL")
  body   String

  readAt    DateTime? // null until the VA has seen it
  createdAt DateTime  @default(now())

  @@index([entryId])
  @@index([authorId])
}

// A daily Flappy Bird score. One row per user per ET day (they play once a day
// after clocking in). `playDate` is the ET calendar day at UTC-midnight, like
// TimeEntry.workDate. The all-time best per user powers the leaderboard.
model GameScore {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("GameScores", fields: [userId], references: [id], onDelete: Cascade)

  score    Int
  playDate DateTime // the ET day this score was set (one play per day)

  createdAt DateTime @default(now())

  @@unique([userId, playDate])
  @@index([score])
}

// A message the Sales Producer sends to a fixed team channel from the Sales
// Desk. Each recipient gets their OWN row so per-person read state is
// independent — it shows on the recipient's dashboard (VA or admin) as a "new
// message" notice until they dismiss it (readAt set). No email is sent.
model Notice {
  id String @id @default(cuid())

  // Which channel it was sent to: "TECH_SUPPORT" | "ADMIN_INQUIRY".
  channel String
  body    String

  senderId String
  sender   User   @relation("NoticeSender", fields: [senderId], references: [id], onDelete: Cascade)

  recipientId String
  recipient   User   @relation("NoticeRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  readAt    DateTime? // null until the recipient dismisses it
  createdAt DateTime  @default(now())

  @@index([recipientId, readAt])
  @@index([senderId])
}
