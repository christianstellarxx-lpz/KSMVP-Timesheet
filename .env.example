# ---------------------------------------------------------------------------
# KSMVP VA Tasks — environment variables
# Copy this file to `.env` and fill in real values:  cp .env.example .env
# ---------------------------------------------------------------------------

# Database connection string — PostgreSQL (used for BOTH local dev and prod).
#
# Create a free hosted Postgres (Neon, Vercel Postgres, Supabase, …) and paste
# its connection string here. Use the DIRECT / non-pooled URL so migrations run
# cleanly. The SAME URL works locally and on Vercel.
#
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
#
DATABASE_URL="postgresql://user:password@host:5432/ksmvp?sslmode=require"

# Secret used to sign session (JWT) cookies. MUST be set and kept private.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string-at-least-32-chars"

# Note: every seeded account starts with the 4-digit PIN 0000 (see DEFAULT_PIN
# in src/lib/validation.ts). Members change their PIN in Account settings.

# Scheduled-shift benchmark grace window, in minutes (dashboard on-time/late chips).
# Optional — defaults to 5 if unset.
BENCHMARK_GRACE_MINUTES="5"
